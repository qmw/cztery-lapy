          </div>
        </div>

        <!-- Right: Form -->
        <div class="reveal-right">
          <form
            class="nb4 nb-shadow-yellow bg-[var(--color-paper)] p-7 lg:p-9 rot-1"
            style="transform:rotate(1.5deg)"
            onsubmit="this.innerHTML='<div class=\'text-center py-12\'><div class=\'disp text-5xl mb-4\'>🐾</div><div class=\'disp text-3xl mb-3\'>DZIĘKUJEMY!</div><p class=\'mono text-sm font-500\'>Odezwiemy się wkrótce.</p></div>'; return false;"
          >
            <p class="mono text-xs font-700 uppercase mb-6 border-b-[2px] border-dashed border-[var(--color-ink)] pb-4">
              // Formularz rejestracji — Cztery Łapy
            </p>

            <div class="grid gap-4 sm:grid-cols-2">
              <label class="mono text-xs font-700 uppercase">
                Imię i nazwisko *
                <input type="text" required placeholder="Jan Kowalski"
                  class="nb2 mt-1 w-full bg-[var(--color-cream)] px-3 py-2.5 font-body text-base outline-none focus:bg-[var(--color-yellow)]" />
              </label>
              <label class="mono text-xs font-700 uppercase">
                Telefon *
                <input type="tel" required placeholder="+48 123 456 789"
                  class="nb2 mt-1 w-full bg-[var(--color-cream)] px-3 py-2.5 font-body text-base outline-none focus:bg-[var(--color-yellow)]" />
              </label>
              <label class="mono text-xs font-700 uppercase">
                E-mail
                <input type="email" placeholder="jan@email.pl"
                  class="nb2 mt-1 w-full bg-[var(--color-cream)] px-3 py-2.5 font-body text-base outline-none focus:bg-[var(--color-yellow)]" />
              </label>
              <label class="mono text-xs font-700 uppercase">
                Gatunek *
                <select required class="nb2 mt-1 w-full bg-[var(--color-cream)] px-3 py-2.5 font-body text-base outline-none focus:bg-[var(--color-yellow)] appearance-none">
                  <option value="" disabled selected>Wybierz...</option>
                  <option>🐕 Pies</option>
                  <option>🐈 Kot</option>
                  <option>🐇 Królik</option>
                  <option>🐹 Gryzoń</option>
                  <option>🐦 Ptak</option>
                  <option>🦎 Gad</option>
                  <option>Inne</option>
                </select>
              </label>
              <label class="mono text-xs font-700 uppercase">
                Rodzaj wizyty
                <select class="nb2 mt-1 w-full bg-[var(--color-cream)] px-3 py-2.5 font-body text-base outline-none focus:bg-[var(--color-yellow)] appearance-none">
                  <option>Wizyta ogólna</option>
                  <option>Szczepienie</option>
                  <option>Konsultacja chirurgiczna</option>
                  <option>Stomatologia</option>
                  <option>USG / RTG</option>
                  <option>Senior Program</option>
                  <option>Nagły przypadek</option>
                </select>
              </label>
              <label class="mono text-xs font-700 uppercase">
                Preferowany termin
                <input type="text" placeholder="np. wtorek rano..."
                  class="nb2 mt-1 w-full bg-[var(--color-cream)] px-3 py-2.5 font-body text-base outline-none focus:bg-[var(--color-yellow)]" />
              </label>
            </div>

            <label class="mono text-xs font-700 uppercase mt-4 block">
              Dodatkowe informacje
              <textarea rows="3" placeholder="Opisz objawy lub cel wizyty..."
                class="nb2 mt-1 w-full bg-[var(--color-cream)] px-3 py-2.5 font-body text-base outline-none focus:bg-[var(--color-yellow)] resize-none"></textarea>
            </label>

            <button type="submit" class="disp nb4 nb-shadow nb-press mt-6 w-full bg-[var(--color-pink)] px-6 py-4 text-xl text-white">
              WYŚLIJ ZGŁOSZENIE 🐾 →
