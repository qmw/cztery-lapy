---
import Layout from "../layouts/Layout.astro";

const U = "https://images.unsplash.com/";
const q = "?auto=format&fit=crop&q=80";
const img = {
  dog1:   U + "photo-1587300003388-59208cc962cb" + q + "&w=900",
  dog2:   U + "photo-1548199973-03cce0bbc87b" + q + "&w=700",
  cat1:   U + "photo-1596492784531-6e6eb5ea9993" + q + "&w=700",
  vet1:   U + "photo-1559839734-2b71ea197ec2" + q + "&w=600",
  vet2:   U + "photo-1612349317150-e413f6a5b16d" + q + "&w=600",
  vet3:   U + "photo-1594824476967-48c8b964273f" + q + "&w=600",
  vet4:   U + "photo-1582750433449-648ed127bb54" + q + "&w=600",
  clinic: U + "photo-1581888227599-779811939961" + q + "&w=700",
};

const uslugi = [
  {
    icon: "🛡️",
    name: "Profilaktyka i szczepienia",
    desc: "Pełne programy szczepień, odrobaczanie, paszport zwierzęcia. Twój pupil bezpieczny przez cały rok.",
    price: "od 80 zł",
    bg: "bg-[var(--color-soft-green)]",
    accent: "var(--color-teal)",
  },
  {
    icon: "🩺",
    name: "Chirurgia",
    desc: "Zabiegi przez doświadczonych specjalistów. Pełny monitoring anestezjologiczny. Sala wyposażona na najwyższym poziomie.",
    price: "od 350 zł",
    bg: "bg-[var(--color-coral-light)]",
    accent: "var(--color-coral)",
  },
  {
    icon: "🦷",
    name: "Stomatologia zwierząt",
    desc: "Kamień nazębny, ekstrakcje, choroby przyzębia. Znieczulenie ogólne w standardzie. Zadbaj o zdrowie jamy ustnej pupila!",
    price: "od 250 zł",
    bg: "bg-[var(--color-yellow-light)]",
    accent: "var(--color-yellow)",
  },
  {
    icon: "🔬",
    name: "USG / RTG",
    desc: "Ultrasonografia jamy brzusznej i serca. Radiografia cyfrowa. Wyniki tego samego dnia!",
    price: "od 150 zł",
    bg: "bg-[var(--color-soft-green)]",
    accent: "var(--color-teal)",
  },
  {
    icon: "🌿",
    name: "Opieka nad seniorami",
    desc: "Program geriatryczny dla zwierząt 7+. Badania krwi, ocena bólu, dieta i suplementacja dopasowana do wieku.",
    price: "od 120 zł",
    bg: "bg-[var(--color-coral-light)]",
    accent: "var(--color-coral)",
  },
  {
    icon: "🌙",
    name: "Dyżur całodobowy",
    desc: "Pomoc w nagłych przypadkach non-stop. Hospitalizacja i intensywna terapia 24 godziny na dobę.",
    price: "od 200 zł",
    bg: "bg-[var(--color-yellow-light)]",
    accent: "var(--color-yellow)",
  },
];

const team = [
  { name: "Anna Kowalska",     rola: "Chirurg / Kierownik", spec: "Chirurgia, ortopedia",    img: img.vet1, years: 12 },
  { name: "Marek Nowak",       rola: "Internista",           spec: "Diagnostyka, USG",        img: img.vet2, years: 8 },
  { name: "Zofia Wiśniewska",  rola: "Stomatolog wet.",      spec: "Stomatologia, jama ustna",img: img.vet3, years: 6 },
  { name: "Piotr Jabłoński",   rola: "Spec. geriatrii",      spec: "Seniory, kardiologia",    img: img.vet4, years: 10 },
];

const schedule = [
  { day: "Poniedziałek – Piątek", hours: "8:00 – 20:00", emergency: false },
  { day: "Sobota",                hours: "9:00 – 17:00", emergency: false },
  { day: "Niedziela",             hours: "10:00 – 15:00",emergency: false },
  { day: "Dyżur nocny 24/7",      hours: "+48 22 456 78 90", emergency: true },
];

const reviews = [
  { name: "Katarzyna M.", pet: "mama Maksa (labrador)", stars: 5,
    text: "Niesamowity zespół! Dr Kowalska operowała naszego Maksa — efekt fenomenalny. Przez cały czas czułyśmy się zaopiekowane.", bg: "bg-[var(--color-soft-green)]" },
  { name: "Tomasz W.", pet: "tata Piratki (bengal)", stars: 5,
    text: "Najlepsza klinika w Warszawie. Profesjonalizm, nowoczesny sprzęt i prawdziwa troska. Kot nigdy nie był tak spokojny u weterynarza!", bg: "bg-[var(--color-yellow-light)]" },
  { name: "Agnieszka L.", pet: "mama Buni (króliczka)", stars: 5,
    text: "Świetna opieka nad Bunią po zabiegu. Dr Wiśniewska wszystko wytłumaczyła. Gabinet czysty, przyjemny — zwierzęta tu nie boją się!", bg: "bg-[var(--color-coral-light)]" },
  { name: "Rafał K.", pet: "tata Bolka (golden)", stars: 5,
    text: "Korzystamy z kliniki 5 lat i nigdy się nie zawiedliśmy. Program opieki nad seniorem dla Bolka na najwyższym poziomie!", bg: "bg-white" },
];
---

<Layout>
  <!-- ===== NAV ===== -->
  <nav id="nav" class="fixed inset-x-0 z-40 bg-[var(--color-cream)]">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3 lg:px-8">

      <!-- Logo -->
      <a href="#top" class="flex items-center gap-2 group">
        <span class="text-2xl">🐾</span>
        <span class="disp text-xl font-600 text-[var(--color-ink)] leading-tight">
          Cztery<span class="text-[var(--color-teal)]"> Łapy</span>
        </span>
      </a>

      <!-- Desktop links -->
      <div class="hidden items-center gap-1 md:flex">
        {["O klinice","Usługi","Zespół","Godziny","Opinie"].map((l, i) => (
          <a
            href={`#${["o-klinice","uslugi","zespol","godziny","opinie"][i]}`}
            class="px-4 py-2 text-sm font-600 text-[var(--color-ink-soft)] rounded-full hover:bg-[var(--color-soft-green)] hover:text-[var(--color-teal-dark)] transition-colors"
          >{l}</a>
        ))}
        <a href="#kontakt"
           class="ml-2 px-5 py-2.5 rounded-full bg-[var(--color-teal)] text-white text-sm font-700 shadow-sm hover:bg-[var(--color-teal-dark)] transition-colors">
          Umów wizytę 🐾
        </a>
      </div>

      <!-- Mobile burger -->
      <button id="burger"
              class="rounded-full bg-[var(--color-soft-green)] px-4 py-2 text-sm font-700 text-[var(--color-teal-dark)] md:hidden"
              aria-label="Menu">
        Menu
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden bg-white px-5 pb-5 pt-2 md:hidden soft-shadow">
      <div class="flex flex-col gap-1 text-sm font-600">
        {["O klinice","Usługi","Zespół","Godziny","Opinie","Kontakt"].map((l, i) => (
          <a href={`#${["o-klinice","uslugi","zespol","godziny","opinie","kontakt"][i]}`}
             class="py-2 px-3 rounded-xl text-[var(--color-ink)] hover:bg-[var(--color-soft-green)] hover:text-[var(--color-teal-dark)] transition-colors">{l}</a>
        ))}
        <a href="#kontakt"
           class="mt-2 rounded-full bg-[var(--color-teal)] py-3 text-center text-white font-700 hover:bg-[var(--color-teal-dark)] transition-colors">
          Umów wizytę 🐾
        </a>
      </div>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <header id="top" class="relative overflow-hidden bg-[var(--color-cream)] pt-28 pb-0 lg:pt-32">
    <!-- Organic blob bg shapes -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
      <!-- teal blob top-right -->
      <svg class="absolute -right-40 -top-40 w-[600px] opacity-25" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
        <path d="M420,60 C520,80 580,160 570,270 C560,380 480,450 370,460 C260,470 160,410 110,310 C60,210 90,90 190,50 C290,10 320,40 420,60Z" fill="var(--color-teal)"/>
      </svg>
      <!-- coral blob bottom-left -->
      <svg class="absolute -bottom-20 -left-32 w-[480px] opacity-20" viewBox="0 0 480 480" xmlns="http://www.w3.org/2000/svg">
        <path d="M300,40 C390,60 450,140 440,240 C430,340 360,400 260,410 C160,420 80,360 50,260 C20,160 60,70 150,40 C240,10 210,20 300,40Z" fill="var(--color-coral)"/>
      </svg>
      <!-- yellow small blob mid -->
      <svg class="absolute right-1/4 bottom-20 w-[280px] opacity-30" viewBox="0 0 280 280" xmlns="http://www.w3.org/2000/svg">
        <path d="M180,30 C230,50 260,110 250,170 C240,230 190,270 130,265 C70,260 20,210 20,150 C20,90 60,30 120,25 C150,22 160,20 180,30Z" fill="var(--color-yellow)"/>
      </svg>
    </div>

    <div class="relative mx-auto max-w-6xl px-5 lg:px-8">
      <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_1fr]">

        <!-- Left: text -->
        <div class="relative z-10">
          <!-- Pill badge -->
          <div class="mb-5 inline-flex items-center gap-2 rounded-full bg-[var(--color-teal-light)] px-4 py-2 text-sm font-700 text-[var(--color-teal-dark)]">
            <span>🏆</span> Klinika z 15-letnim doświadczeniem · Warszawa
          </div>

          <h1 class="disp text-5xl font-600 leading-tight text-[var(--color-ink)] lg:text-6xl xl:text-7xl">
            Twój pupil<br/>
            <span class="text-[var(--color-teal)]">w dobrych</span><br/>
            łapach
            <span class="ml-1 text-4xl">🐾</span>
          </h1>

          <p class="mt-6 max-w-md text-lg font-500 leading-relaxed text-[var(--color-ink-soft)]">
            Klinika weterynaryjna z sercem — profesjonalna opieka, nowoczesny sprzęt
            i prawdziwa troska o każde zwierzę.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#kontakt"
               class="rounded-full bg-[var(--color-teal)] px-7 py-3.5 text-base font-700 text-white soft-shadow-teal hover:bg-[var(--color-teal-dark)] transition-colors">
              Umów wizytę online →
            </a>
            <a href="#uslugi"
               class="rounded-full bg-white px-7 py-3.5 text-base font-700 text-[var(--color-ink)] soft-shadow hover:bg-[var(--color-soft-green)] transition-colors">
              Nasze usługi
            </a>
          </div>

          <!-- Stats pills -->
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="flex items-center gap-1.5 rounded-full bg-[var(--color-yellow-light)] px-4 py-2 text-sm font-700 text-[var(--color-ink)]">
              ⭐ 4,97 / 5 · 620+ opinii
            </span>
            <span class="flex items-center gap-1.5 rounded-full bg-[var(--color-coral-light)] px-4 py-2 text-sm font-700 text-[var(--color-ink)]">
              🕐 Dyżur 24/7
            </span>
            <span class="flex items-center gap-1.5 rounded-full bg-[var(--color-soft-green)] px-4 py-2 text-sm font-700 text-[var(--color-teal-dark)]">
              🐶🐱 Każde zwierzę mile widziane
            </span>
          </div>
        </div>

        <!-- Right: photo + floating cards -->
        <div class="relative z-10 mt-4 lg:mt-0">
          <!-- Main image — big rounded -->
          <div class="overflow-hidden rounded-[2.5rem] soft-shadow-lg">
            <img src={img.dog1} alt="Szczęśliwy pies w klinice Cztery Łapy"
                 class="aspect-[4/5] w-full object-cover" loading="eager" />
          </div>

          <!-- Floating card 1: patients -->
          <div class="absolute -left-6 bottom-16 rounded-2xl bg-white p-4 soft-shadow-teal hidden sm:block">
            <div class="text-2xl">🐾</div>
            <div class="disp mt-1 text-2xl font-600 text-[var(--color-teal)]">3 200+</div>
            <div class="text-xs font-600 text-[var(--color-ink-soft)]">pacjentów rocznie</div>
          </div>

          <!-- Floating card 2: rating -->
          <div class="absolute -right-4 top-8 rounded-2xl bg-white p-4 soft-shadow hidden sm:block">
            <div class="flex gap-0.5 text-[var(--color-yellow)] text-lg">★★★★★</div>
            <div class="disp mt-1 text-xl font-600 text-[var(--color-ink)]">4,97 / 5</div>
            <div class="text-xs font-600 text-[var(--color-ink-soft)]">Google · 620 opinii</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave separator at bottom -->
    <div class="wave-sep mt-10">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="white"/>
      </svg>
    </div>
  </header>

  <!-- ===== O KLINICE ===== -->
  <section id="o-klinice" class="bg-white px-5 py-20 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-6xl">

      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <!-- Image mosaic -->
        <div class="reveal-left relative">
          <div class="grid grid-cols-2 gap-4">
            <div class="overflow-hidden rounded-[2rem] soft-shadow">
              <img src={img.dog2} alt="Pies w klinice" class="aspect-[4/5] w-full object-cover" loading="lazy" />
            </div>
            <div class="space-y-4 pt-8">
              <div class="overflow-hidden rounded-[2rem] soft-shadow">
                <img src={img.clinic} alt="Gabinet kliniki" class="aspect-square w-full object-cover" loading="lazy" />
              </div>
              <!-- Experience badge -->
              <div class="rounded-2xl bg-[var(--color-teal)] p-4 text-center soft-shadow-teal">
                <div class="disp text-3xl font-600 text-white">15 lat</div>
                <div class="text-sm font-600 text-white/80">doświadczenia</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="reveal-right">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-[var(--color-soft-green)] px-4 py-2 text-sm font-700 text-[var(--color-teal-dark)]">
            ❤️ O naszej klinice
          </div>
          <h2 class="disp text-4xl font-600 text-[var(--color-ink)] leading-tight lg:text-5xl">
            Medycyna weterynaryjna<br/>
            <span class="text-[var(--color-teal)]">z ludzką twarzą</span>
          </h2>
          <p class="mt-5 text-base font-500 leading-relaxed text-[var(--color-ink-soft)]">
            Klinika Cztery Łapy powstała z pasji do zwierząt i przekonania, że każdy pupil zasługuje
            na opiekę medyczną najwyższej klasy. Łączymy nowoczesną medycynę z ciepłym, ludzkim podejściem.
          </p>
          <p class="mt-4 text-base font-500 leading-relaxed text-[var(--color-ink-soft)]">
            Nasz zespół tworzą doświadczeni lekarze weterynarii — specjaliści z pasją, którzy nieustannie
            podnoszą kwalifikacje. Wyposażenie spełnia najwyższe standardy, a atmosfera sprawia,
            że nawet nerwowe zwierzęta szybko się uspokajają.
          </p>

          <!-- Feature tags -->
          <div class="mt-6 flex flex-wrap gap-2">
            {[
              ["🔬","Nowoczesny sprzęt"],
              ["🎓","Certyfikowani specjaliści"],
              ["😊","Przyjazna atmosfera"],
              ["💊","Apteka weterynaryjna"],
              ["🌙","Dyżur całodobowy"],
              ["📋","Pełna dokumentacja"],
            ].map(([icon, f]) => (
              <span class="flex items-center gap-1.5 rounded-full bg-[var(--color-cream)] px-3 py-1.5 text-sm font-600 text-[var(--color-ink)]">
                {icon} {f}
              </span>
            ))}
          </div>

          <!-- Stats row -->
          <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
            {[
              { n: "3 200+", l: "pacjentów rocznie", bg: "bg-[var(--color-soft-green)]", col: "text-[var(--color-teal-dark)]" },
              { n: "15",     l: "lat doświadczenia", bg: "bg-[var(--color-coral-light)]",col: "text-[var(--color-coral)]" },
              { n: "98%",    l: "zadowolonych",       bg: "bg-[var(--color-yellow-light)]",col: "text-[var(--color-ink)]" },
              { n: "24/7",   l: "dyżur alarmowy",     bg: "bg-[var(--color-teal)] text-white", col: "text-white" },
            ].map((s, i) => (
              <div class={`reveal rounded-2xl p-4 text-center soft-shadow-sm ${s.bg} delay-${i+1}`}>
                <div class={`disp text-3xl font-600 ${s.col}`}>{s.n}</div>
                <div class={`mt-1 text-xs font-600 opacity-70 ${s.col}`}>{s.l}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave -->
  <div class="wave-sep bg-white">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1360,20 1440,30 L1440,60 L0,60 Z" fill="var(--color-cream)"/>
    </svg>
  </div>

  <!-- ===== USŁUGI ===== -->
  <section id="uslugi" class="bg-[var(--color-cream)] px-5 py-20 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-6xl">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-700 text-[var(--color-teal-dark)] soft-shadow-sm">
        🩺 Nasze specjalizacje
      </div>
      <h2 class="disp text-4xl font-600 text-[var(--color-ink)] leading-tight lg:text-5xl">
        Kompleksowa opieka<br/>
        <span class="text-[var(--color-teal)]">w jednym miejscu</span>
      </h2>
      <p class="mt-4 max-w-xl text-base font-500 text-[var(--color-ink-soft)]">
        6 specjalizacji pod jednym dachem — wszystko czego potrzebuje Twój pupil, od profilaktyki po zaawansowaną diagnostykę.
      </p>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {uslugi.map((u, i) => (
          <div class={`reveal rounded-3xl ${u.bg} p-7 soft-shadow-sm hover:soft-shadow transition-shadow delay-${Math.min(i+1,4)}`}>
            <div class="mb-3 text-4xl">{u.icon}</div>
            <h3 class="disp text-xl font-600 text-[var(--color-ink)]">{u.name}</h3>
            <p class="mt-3 text-sm font-500 leading-relaxed text-[var(--color-ink-soft)]">{u.desc}</p>
            <div class="mt-5 flex items-center justify-between">
              <span class="rounded-full bg-white px-3 py-1 text-sm font-700" style={`color:${u.accent}`}>
                {u.price}
              </span>
              <a href="#kontakt"
                 class="rounded-full bg-white px-4 py-1.5 text-xs font-700 text-[var(--color-ink)] soft-shadow-sm hover:bg-[var(--color-teal)] hover:text-white transition-colors">
                Umów →
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-8 text-center text-xs font-500 text-[var(--color-ink-soft)]/70">
        * Ceny orientacyjne — dokładna wycena po konsultacji. Dostępne plany opieki abonamentowej.
      </p>
    </div>
  </section>

  <!-- Wave -->
  <div class="wave-sep bg-[var(--color-cream)]">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,20 C480,60 960,0 1440,40 L1440,60 L0,60 Z" fill="var(--color-teal-light)"/>
    </svg>
  </div>

  <!-- ===== ZESPÓŁ ===== -->
  <section id="zespol" class="bg-[var(--color-teal-light)] px-5 py-20 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-6xl">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-700 text-[var(--color-teal-dark)] soft-shadow-sm">
        👩‍⚕️ Nasz zespół
      </div>
      <h2 class="disp text-4xl font-600 text-[var(--color-ink)] leading-tight lg:text-5xl">
        Lekarze, którym<br/>
        <span class="text-[var(--color-teal)]">możesz zaufać</span>
      </h2>
      <p class="mt-4 max-w-lg text-base font-500 text-[var(--color-ink-soft)]">
        Nasi specjaliści łączą wiedzę, doświadczenie i prawdziwą miłość do zwierząt.
      </p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {team.map((doc, i) => (
          <figure class={`reveal rounded-3xl overflow-hidden bg-white soft-shadow delay-${Math.min(i+1,4)}`}>
            <div class="relative overflow-hidden">
              <img src={doc.img} alt={doc.name} loading="lazy"
                   class="aspect-[3/4] w-full object-cover hover:scale-105 transition-transform duration-500" />
              <!-- Soft overlay at bottom -->
              <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/40 to-transparent"></div>
              <div class="absolute bottom-3 left-3 right-3">
                <span class="inline-block rounded-full bg-white/90 px-3 py-1 text-xs font-700 text-[var(--color-teal-dark)]">
                  {doc.rola}
                </span>
              </div>
            </div>
            <figcaption class="p-5">
              <p class="disp text-lg font-600 text-[var(--color-ink)]">{doc.name}</p>
              <p class="mt-1 text-sm font-500 text-[var(--color-ink-soft)]">{doc.spec}</p>
              <div class="mt-3 flex items-center gap-1.5 text-xs font-700 text-[var(--color-teal-dark)]">
                <span class="text-base">⭐</span> {doc.years} lat doświadczenia
              </div>
            </figcaption>
          </figure>
        ))}
      </div>

      <!-- Recruitment card -->
      <div class="mt-14 reveal">
        <div class="rounded-3xl bg-[var(--color-teal)] p-8 lg:p-10 soft-shadow-teal max-w-2xl">
          <div class="mb-3 text-3xl">💼</div>
          <h3 class="disp text-3xl font-600 text-white lg:text-4xl">Dołącz do naszego zespołu</h3>
          <p class="mt-3 text-base font-500 text-white/80">
            Szukamy doświadczonego lekarza weterynarii z pasją. Napisz do nas!
          </p>
          <a href="mailto:praca@czterylapy.pl"
