---
import Layout from "../layouts/Layout.astro";

const U = "https://images.unsplash.com/";
const q = "?auto=format&fit=crop&q=80";
const img = {
  dog1:  U + "photo-1587300003388-59208cc962cb" + q + "&w=900",
  dog2:  U + "photo-1548199973-03cce0bbc87b" + q + "&w=700",
  cat1:  U + "photo-1596492784531-6e6eb5ea9993" + q + "&w=700",
  vet1:  U + "photo-1559839734-2b71ea197ec2" + q + "&w=600",
  vet2:  U + "photo-1612349317150-e413f6a5b16d" + q + "&w=600",
  vet3:  U + "photo-1594824476967-48c8b964273f" + q + "&w=600",
  vet4:  U + "photo-1582750433449-648ed127bb54" + q + "&w=600",
  clinic:U + "photo-1581888227599-779811939961" + q + "&w=700",
};

const uslugi = [
  {
    nr: "01", name: "Profilaktyka\ni szczepienia",
    desc: "Pełne programy szczepień, odrobaczanie, paszport zwierzęcia. Twój pupil bezpieczny przez cały rok.",
    price: "od 80 zł",
    bg: "bg-[var(--color-yellow)]",
    shadow: "nb-shadow",
  },
  {
    nr: "02", name: "Chirurgia",
    desc: "Zabiegi przez doświadczonych specjalistów. Pełny monitoring anestezjologiczny. Sala wyposażona na 5★.",
    price: "od 350 zł",
    bg: "bg-[var(--color-blue)]",
    shadow: "nb-shadow-yellow",
    textLight: true,
  },
  {
    nr: "03", name: "Stomatologia zwierząt",
    desc: "Kamień nazębny, ekstrakcje, choroby przyzębia. Znieczulenie ogólne w standardzie. Piękny uśmiech!",
    price: "od 250 zł",
    bg: "bg-[var(--color-pink)]",
    shadow: "nb-shadow",
    textLight: true,
  },
  {
    nr: "04", name: "USG / RTG",
    desc: "Ultrasonografia jamy brzusznej i serca. Radiografia cyfrowa. Wyniki tego samego dnia!",
    price: "od 150 zł",
    bg: "bg-[var(--color-paper)]",
    shadow: "nb-shadow-blue",
  },
  {
    nr: "05", name: "Opieka\nnad seniorami",
    desc: "Program geriatryczny dla zwierząt 7+. Badania krwi, ocena bólu, dieta, suplementacja.",
    price: "od 120 zł",
    bg: "bg-[var(--color-yellow-light)]",
    shadow: "nb-shadow-pink",
  },
  {
    nr: "06", name: "Dyżur\ncałodobowy",
    desc: "Pomoc w nagłych przypadkach non-stop. Hospitalizacja i intensywna terapia 24 godziny na dobę.",
    price: "od 200 zł",
    bg: "bg-[var(--color-ink)]",
    shadow: "nb-shadow-yellow",
    textLight: true,
  },
];

const team = [
  { name: "Anna\nKowalska", rola: "Chirurg / Kierownik", spec: "Chirurgia, ortopedia", img: img.vet1, years: 12, bg: "bg-[var(--color-yellow)]", rot: "rot-2" },
  { name: "Marek\nNowak",   rola: "Internista",          spec: "Diagnostyka, USG",    img: img.vet2, years: 8,  bg: "bg-[var(--color-blue)]",   rot: "rot-1", light: true },
  { name: "Zofia\nWiśniewska", rola: "Stomatolog wet.",  spec: "Stom., jama ustna",   img: img.vet3, years: 6,  bg: "bg-[var(--color-pink)]",   rot: "rot-2", light: true },
  { name: "Piotr\nJabłoński",  rola: "Spec. geriatrii",  spec: "Seniory, kardiologia",img: img.vet4, years: 10, bg: "bg-[var(--color-paper)]",  rot: "rot-1" },
];

const schedule = [
  { day: "Poniedziałek – Piątek", hours: "8:00 – 20:00", accent: false },
  { day: "Sobota",                hours: "9:00 – 17:00", accent: false },
  { day: "Niedziela",             hours: "10:00 – 15:00",accent: false },
  { day: "Dyżur nocny 24/7",      hours: "+48 22 456 78 90", accent: true },
];

const reviews = [
  { name: "Katarzyna M.", pet: "mama Maksa (labrador)", stars: 5, rot: "rot-1",
    text: "Niesamowity zespół! Dr Kowalska operowała naszego Maksa — efekt fenomenalny. Przez cały czas czułyśmy się zaopiekowane.", bg: "bg-[var(--color-yellow)]" },
  { name: "Tomasz W.", pet: "tata Piratki (bengal)", stars: 5, rot: "rot-2",
    text: "Najlepsza klinika w Warszawie. Profesjonalizm, nowoczesny sprzęt i prawdziwa troska. Kot nigdy nie był tak spokojny u weterynarza!", bg: "bg-[var(--color-blue-light)]" },
  { name: "Agnieszka L.", pet: "mama Buni (króliczka)", stars: 5, rot: "rot-1",
    text: "Świetna opieka nad Bunią po zabiegu. Dr Wiśniewska wszystko wytłumaczyła. Gabinet czysty, przyjemny — zwierzęta tu nie boją się!", bg: "bg-[var(--color-pink-light)]" },
  { name: "Rafał K.", pet: "tata Bolka (golden)", stars: 5, rot: "rot-3",
    text: "Korzystamy z kliniki 5 lat i nigdy się nie zawiedliśmy. Program opieki nad seniorem dla Bolka na najwyższym poziomie!", bg: "bg-[var(--color-paper)]" },
];

const marquee = ["SZCZEPIENIA", "CHIRURGIA", "STOMATOLOGIA", "USG / RTG", "SENIORY", "DYŻUR 24H", "TWÓJ PUPIL BEZPIECZNY"];
---

<Layout>
  <!-- ===== NAV ===== -->
  <nav id="nav" class="fixed inset-x-0 z-40 border-b-[3px] border-[var(--color-ink)] bg-[var(--color-cream)]">
    <div class="mx-auto flex max-w-[1400px] items-center justify-between px-4 py-3 lg:px-8">
      <!-- Logo — sticker style -->
      <a href="#top" class="group flex items-center gap-2">
        <span class="disp nb nb-shadow bg-[var(--color-blue)] px-3 py-1.5 text-xl text-white inline-block rot-1">CZTERY</span>
        <span class="disp nb nb-shadow-pink bg-[var(--color-pink)] px-3 py-1.5 text-xl text-white inline-block rot-2">ŁAPY</span>
      </a>

      <!-- Desktop links -->
      <div class="hidden items-center gap-1 md:flex">
        {["O klinice", "Usługi", "Zespół", "Godziny", "Opinie"].map((l, i) => (
          <a
            href={`#${["o-klinice","uslugi","zespol","godziny","opinie"][i]}`}
            class="mono nb2 bg-[var(--color-paper)] px-3 py-1.5 text-xs font-500 uppercase hover:bg-[var(--color-yellow)] transition-colors"
          >{l}</a>
        ))}
        <a href="#kontakt" class="disp nb nb-shadow nb-press bg-[var(--color-pink)] px-5 py-1.5 text-sm text-white">Umów wizytę 🐾</a>
      </div>

      <button id="burger" class="nb2 bg-[var(--color-yellow)] px-3 py-2 md:hidden" aria-label="Menu">
        <span class="mono text-sm font-700">MENU</span>
      </button>
    </div>

    <div id="mobile-menu" class="hidden border-t-[3px] border-[var(--color-ink)] bg-[var(--color-cream)] px-4 py-4 md:hidden">
      <div class="mono flex flex-col gap-2 text-sm font-700 uppercase">
        <a href="#o-klinice">O klinice</a>
        <a href="#uslugi">Usługi</a>
        <a href="#zespol">Zespół</a>
        <a href="#godziny">Godziny</a>
        <a href="#opinie">Opinie</a>
        <a href="#kontakt" class="nb bg-[var(--color-pink)] px-4 py-2 text-center text-white">Umów wizytę 🐾</a>
      </div>
    </div>
  </nav>

  <!-- ===== HERO (asymetryczny, brutalistyczny) ===== -->
  <header id="top" class="relative overflow-hidden bg-[var(--color-cream)] px-4 pb-10 pt-28 lg:px-8 lg:pt-32">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid items-start gap-8 lg:grid-cols-[1.2fr_1fr]">

        <!-- Left: big type + CTA -->
        <div class="relative">
          <!-- Badge naklejka -->
          <div class="mono nb nb-shadow-blue inline-block bg-[var(--color-blue-light)] px-3 py-1 text-xs font-500 uppercase rot-2 mb-4">
            🏆 Klinika · 15 lat · Warszawa
          </div>

          <h1 class="disp mt-2 text-[16vw] leading-[0.85] lg:text-[9.5vw]">
            <span class="block">TWÓJ</span>
            <span class="block text-[var(--color-blue)]">PUPIL</span>
            <span class="block stroke-ink">W DOBRYCH</span>
            <span class="block">ŁAPACH.</span>
          </h1>

          <p class="mt-6 max-w-sm text-xl font-500 leading-snug lg:text-2xl">
            Klinika weterynaryjna z sercem — profesjonalna opieka, nowoczesny sprzęt i prawdziwa troska o każde zwierzę.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href="#kontakt" class="disp nb nb-shadow-lg nb-press bg-[var(--color-pink)] px-8 py-4 text-xl text-white">
              UMÓW WIZYTĘ →
            </a>
            <a href="#uslugi" class="mono nb2 nb-press bg-[var(--color-paper)] px-6 py-4 text-sm font-500 uppercase">
              Nasze usługi
            </a>
          </div>

          <!-- Small stats stickers -->
          <div class="mt-8 flex flex-wrap gap-4">
            <span class="mono nb nb-shadow-yellow bg-[var(--color-yellow)] px-3 py-2 text-sm font-700 rot-1">
              ⭐ 4.97 / 5 · 620+ opinii
            </span>
            <span class="mono nb nb-shadow-pink bg-[var(--color-pink-light)] px-3 py-2 text-sm font-700 rot-2">
              🕐 Dyżur 24 / 7
            </span>
          </div>
        </div>

        <!-- Right: photo collage -->
        <div class="relative mt-6 lg:mt-12">
          <!-- Main photo -->
          <div class="nb4 nb-shadow-lg overflow-hidden bg-[var(--color-ink)] rot-2">
            <img src={img.dog1} alt="Szczęśliwy pies w klinice" class="aspect-[4/5] w-full object-cover" loading="eager" />
          </div>

          <!-- Floating stickers -->
          <div class="disp absolute -bottom-6 -left-6 nb nb-shadow bg-[var(--color-yellow)] px-4 py-3 text-2xl rot-3">
            Z MIŁOŚCIĄ<br/>DO ZWIERZĄT
          </div>

          <div class="mono absolute -right-4 top-8 nb nb-shadow-pink bg-[var(--color-pink)] px-3 py-2 text-xs font-700 text-white rot-1">
            🐾 3200+ pacjentów/rok
          </div>

          <!-- Small inset photo -->
          <div class="absolute -bottom-4 -right-2 w-32 nb4 nb-shadow overflow-hidden bg-[var(--color-ink)] rot-4 hidden lg:block">
            <img src={img.cat1} alt="Kotek u weterynarza" class="aspect-square w-full object-cover" loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ===== MARQUEE ===== -->
  <section class="overflow-hidden border-y-[3px] border-[var(--color-ink)] bg-[var(--color-blue)] py-3">
    <div class="flex whitespace-nowrap">
      <div class="marquee-track flex shrink-0">
        {[...marquee, ...marquee].map((w) => (
          <span class="disp mx-6 text-2xl text-white">{w} <span class="text-[var(--color-yellow)]">✦</span></span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== O KLINICE ===== -->
  <section id="o-klinice" class="px-4 py-20 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-[1400px]">
      <!-- Big rotated heading -->
      <div class="flex items-start gap-6 flex-wrap">
        <h2 class="disp text-[13vw] leading-none lg:text-8xl">
          <span class="bg-[var(--color-ink)] px-3 text-white">O KLINICE</span>
        </h2>
        <div class="mono nb nb-shadow-blue bg-[var(--color-blue-light)] px-4 py-3 text-sm font-500 rot-2 mt-4 max-w-[240px]">
          // Od 2009 roku dbamy o zdrowie pupili mieszkańców Warszawy
        </div>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-[1fr_1.3fr] items-start">
        <!-- Image mosaic -->
        <div class="reveal-left relative">
          <div class="grid grid-cols-2 gap-4">
            <div class="nb4 nb-shadow overflow-hidden bg-[var(--color-ink)] rot-2">
              <img src={img.dog2} alt="Szczęśliwy pies" class="aspect-[4/5] w-full object-cover" loading="lazy" />
            </div>
            <div class="space-y-4 pt-8">
              <div class="nb4 nb-shadow-pink overflow-hidden bg-[var(--color-pink-light)] rot-1">
                <img src={img.clinic} alt="Gabinet kliniki" class="aspect-square w-full object-cover" loading="lazy" />
              </div>
              <!-- Sticker -->
              <div class="disp nb nb-shadow-yellow bg-[var(--color-yellow)] px-4 py-3 text-lg text-center rot-3">
                15 LAT<br/>DOŚWIADCZENIA
              </div>
            </div>
          </div>
        </div>

        <!-- Text block -->
        <div class="reveal-right">
          <p class="text-xl font-500 leading-relaxed mb-6">
            Klinika Cztery Łapy powstała z pasji do zwierząt i przekonania, że każdy pupil zasługuje na opiekę medyczną najwyższej klasy. Łączymy nowoczesną medycynę z ciepłym, ludzkim podejściem.
          </p>
          <p class="text-lg font-500 leading-relaxed text-[var(--color-ink)]/70 mb-10">
            Nasz zespół tworzą doświadczeni lekarze weterynarii — specjaliści z pasją, którzy nieustannie podnoszą kwalifikacje. Wyposażenie spełnia najwyższe standardy, a atmosfera sprawia, że nawet nerwowe zwierzęta szybko się uspokajają.
          </p>

          <!-- Feature tags -->
          <div class="flex flex-wrap gap-3">
            {[
              "Nowoczesny sprzęt",
              "Certyfikowani specjaliści",
              "Przyjazna atmosfera",
              "Apteka wet.",
              "Dyżur całodobowy",
              "Pełna dokumentacja"
            ].map((f, i) => (
              <span class={`mono nb2 px-3 py-1.5 text-sm font-500 ${i % 3 === 0 ? "bg-[var(--color-yellow)]" : i % 3 === 1 ? "bg-[var(--color-blue-light)]" : "bg-[var(--color-pink-light)]"}`}>
                {f}
              </span>
            ))}
          </div>

          <!-- Stats row -->
          <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
            {[
              { n: "3200+", l: "pacjentów rocznie" },
              { n: "15",    l: "lat doświadczenia" },
              { n: "98%",   l: "zadowolonych właścicieli" },
              { n: "24/7",  l: "dyżur alarmowy" },
            ].map((s, i) => (
              <div class={`reveal nb nb-shadow text-center p-4 ${["bg-[var(--color-yellow)]","bg-[var(--color-blue)]","bg-[var(--color-pink)]","bg-[var(--color-paper)]"][i]} delay-${i + 1}`}>
                <div class={`disp text-4xl ${i === 1 || i === 2 ? "text-white" : ""}`}>{s.n}</div>
                <div class={`mono mt-1 text-xs font-500 ${i === 1 || i === 2 ? "text-white/80" : ""}`}>{s.l}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== USŁUGI ===== -->
  <section id="uslugi" class="border-t-[3px] border-[var(--color-ink)] px-4 py-20 lg:px-8 lg:py-28 bg-[var(--color-paper)]">
    <div class="mx-auto max-w-[1400px]">
      <!-- Heading: big + sticker -->
      <div class="flex flex-wrap items-end gap-6 mb-12">
        <h2 class="disp text-[13vw] leading-none lg:text-8xl">
          <span class="text-[var(--color-blue)]">NASZE</span><br/>
          <span class="bg-[var(--color-ink)] px-3 text-white">USŁUGI</span>
        </h2>
        <div class="mono nb nb-shadow-pink bg-[var(--color-pink)] text-white px-4 py-3 text-sm font-500 rot-2 mb-2">
          // 6 specjalizacji · pełna opieka
        </div>
      </div>

      <!-- Asymmetric service grid -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {uslugi.map((u, i) => (
          <div class={`reveal nb4 nb-shadow nb-press ${u.bg} p-7 ${i % 3 === 1 ? "rot-1 lg:mt-8" : i % 3 === 2 ? "rot-2 lg:-mt-4" : ""}`}
               style={i % 3 === 1 ? "transform:rotate(1.5deg)" : i % 3 === 2 ? "transform:rotate(-2deg)" : ""}>
            <div class="flex items-start justify-between">
              <span class={`disp text-6xl ${u.textLight ? "text-white/30" : "text-[var(--color-ink)]/20"}`}>{u.nr}</span>
              <span class={`mono nb2 ${u.textLight ? "border-white/50 bg-white/20 text-white" : "bg-[var(--color-paper)]"} px-3 py-1 text-sm font-700`}>{u.price}</span>
            </div>
            <h3 class={`disp mt-4 text-3xl whitespace-pre-line ${u.textLight ? "text-white" : ""}`}>{u.name}</h3>
            <p class={`mt-3 text-base font-500 leading-snug ${u.textLight ? "text-white/85" : ""}`}>{u.desc}</p>
            <a href="#kontakt" class={`mono mt-5 inline-block nb2 ${u.textLight ? "border-white/60 text-white" : ""} px-4 py-2 text-xs font-700 uppercase hover:bg-[var(--color-yellow)] hover:text-[var(--color-ink)] hover:border-[var(--color-ink)] transition-colors`}>
              Umów wizytę →
            </a>
          </div>
        ))}
      </div>

      <!-- Price disclaimer -->
      <p class="mono mt-10 text-center text-xs font-500 uppercase text-[var(--color-ink)]/50">
        * Ceny orientacyjne — dokładna wycena po konsultacji. Dostępne plany opieki abonamentowej.
      </p>
    </div>
  </section>

  <!-- ===== MARQUEE 2 (pink) ===== -->
  <section class="overflow-hidden border-y-[3px] border-[var(--color-ink)] bg-[var(--color-pink)] py-3">
    <div class="flex whitespace-nowrap">
      <div class="marquee-track flex shrink-0" style="animation-direction:reverse">
        {[...["❤️ Z MIŁOŚCIĄ", "🐶 PIES", "🐱 KOT", "🐇 KRÓLIK", "🦜 PTAK", "🦎 GAD", "🐹 GRYZOŃ", "KAŻDE ZWIERZĘ MILE WIDZIANE"],
          ...["❤️ Z MIŁOŚCIĄ", "🐶 PIES", "🐱 KOT", "🐇 KRÓLIK", "🦜 PTAK", "🦎 GAD", "🐹 GRYZOŃ", "KAŻDE ZWIERZĘ MILE WIDZIANE"]].map((w) => (
          <span class="disp mx-6 text-2xl text-white">{w} <span class="text-[var(--color-yellow)]">✦</span></span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ZESPÓŁ ===== -->
  <section id="zespol" class="bg-[var(--color-ink)] px-4 py-20 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-[1400px]">
      <h2 class="disp text-[13vw] leading-none text-white lg:text-8xl">
        NASZ<span class="text-[var(--color-yellow)]"> ZESPÓŁ</span><span class="text-[var(--color-pink)]">.</span>
      </h2>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {team.map((doc, i) => (
          <figure class={`reveal nb4 nb-shadow overflow-hidden bg-[var(--color-paper)] ${doc.rot} ${i % 2 === 0 ? "" : "lg:mt-10"}`}
                  style={i % 2 === 0 ? "transform:rotate(-2deg)" : "transform:rotate(2.5deg)"}>
            <div class="relative overflow-hidden">
              <img src={doc.img} alt={doc.name} loading="lazy"
                   class="aspect-[3/4] w-full object-cover grayscale contrast-125 hover:grayscale-0 transition-all duration-500" />
              <!-- Mono label overlay -->
              <div class="absolute bottom-0 left-0 right-0 nb2 border-x-0 border-b-0 bg-[var(--color-ink)]/80 px-3 py-2">
                <p class="mono text-xs font-700 uppercase text-white">{doc.rola}</p>
              </div>
            </div>
            <figcaption class={`nb2 border-x-0 border-b-0 ${doc.bg} px-4 py-4`}>
              <p class={`disp text-2xl whitespace-pre-line ${doc.light ? "text-white" : ""}`}>{doc.name}</p>
              <p class={`mono mt-1 text-xs font-500 uppercase ${doc.light ? "text-white/70" : "text-[var(--color-ink)]/60"}`}>{doc.spec}</p>
              <p class={`mono mt-2 text-xs font-700 ${doc.light ? "text-white" : ""}`}>{doc.years} lat doświadczenia</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <!-- Recruitment sticker -->
      <div class="mt-14 reveal">
        <div class="nb4 nb-shadow-yellow bg-[var(--color-yellow)] p-8 lg:p-10 max-w-2xl rot-1" style="transform:rotate(-1deg)">
          <p class="mono text-xs font-700 uppercase mb-3">// Oferta pracy</p>
          <h3 class="disp text-4xl lg:text-5xl mb-4">DOŁĄCZ DO<br/>NASZEGO ZESPOŁU</h3>
          <p class="text-lg font-500 mb-6">Szukamy doświadczonego lekarza weterynarii z pasją. Napisz do nas!</p>
          <a href="mailto:praca@czterylapy.pl" class="disp nb nb-shadow nb-press bg-[var(--color-ink)] px-6 py-3 text-lg text-white inline-block">
            APLIKUJ →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GODZINY ===== -->
  <section id="godziny" class="border-t-[3px] border-[var(--color-ink)] px-4 py-20 lg:px-8 lg:py-28 bg-[var(--color-cream)]">
    <div class="mx-auto max-w-[1400px]">
      <div class="grid gap-12 lg:grid-cols-2 items-start">

        <!-- Hours table -->
        <div class="reveal-left">
          <h2 class="disp text-[13vw] leading-none lg:text-7xl mb-8">
            <span class="bg-[var(--color-blue)] px-3 text-white">GODZINY</span><br/>
            <span>PRZYJĘĆ</span>
          </h2>

          <!-- Schedule "paragon" -->
          <div class="nb4 nb-shadow-blue bg-[var(--color-paper)] p-6 lg:p-8 rot-2" style="transform:rotate(-2deg)">
            <div class="flex items-center justify-between border-b-[3px] border-dashed border-[var(--color-ink)] pb-4 mb-5">
              <span class="mono text-xs font-700 uppercase">// Cztery Łapy · ul. Miodowa 14 · Warszawa</span>
            </div>
            <ul class="space-y-4">
              {schedule.map((item) => (
