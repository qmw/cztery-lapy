              {rev.text}
            </p>
            <div class="flex items-center gap-3 border-t-[2px] border-[var(--color-ink)]/30 pt-4">
              <div class="disp nb nb-shadow-pink bg-[var(--color-pink)] w-12 h-12 flex items-center justify-center text-white text-xl flex-shrink-0">🐾</div>
              <div>
                <p class="disp text-lg">{rev.name}</p>
                <p class="mono text-xs font-500 text-[var(--color-ink)]/60">{rev.pet}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center reveal">
        <a
          href="https://g.page/czterylapy"
          target="_blank"
