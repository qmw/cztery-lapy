  <!-- ===== OPINIE ===== -->
  <section id="opinie" class="border-t-[3px] border-[var(--color-ink)] bg-[var(--color-paper)] px-4 py-20 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-[1400px]">
      <div class="flex flex-wrap items-end gap-6 mb-12">
        <h2 class="disp text-[13vw] leading-none lg:text-8xl">
          <span class="text-[var(--color-pink)]">OPINIE</span>
        </h2>
        <div class="mono nb nb-shadow bg-[var(--color-yellow)] px-4 py-3 text-sm font-700 rot-2 mb-2">
          ★★★★★ 4.97 / 5 · 620+ opinii Google
        </div>
      </div>

      <!-- Scattered card grid -->
      <div class="grid gap-7 sm:grid-cols-2">
        {reviews.map((rev, i) => (
          <div class={`reveal nb4 nb-shadow ${rev.bg} p-7 ${rev.rot}`}
               style={i === 0 ? "transform:rotate(-2.5deg)" : i === 1 ? "transform:rotate(2deg)" : i === 2 ? "transform:rotate(1.5deg)" : "transform:rotate(-1.5deg)"}>
