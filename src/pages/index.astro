---
import Layout from "../layouts/Layout.astro";

const navLinks = [
  { href: "#o-klinice", label: "O klinice" },
  { href: "#uslugi", label: "Usługi" },
  { href: "#zespol", label: "Zespół" },
  { href: "#godziny", label: "Godziny" },
  { href: "#opinie", label: "Opinie" },
  { href: "#kontakt", label: "Kontakt" },
];

const services = [
  {
    icon: "💉",
    title: "Profilaktyka i szczepienia",
    desc: "Kompleksowe programy szczepień, odrobaczanie, profilaktyka przeciw pasożytom zewnętrznym i wewnętrznym. Paszport zwierzęcia i dokumentacja.",
    price: "od 80 zł",
    color: "orange",
  },
  {
    icon: "🔬",
    title: "Chirurgia",
    desc: "Zabiegi chirurgiczne wykonywane przez doświadczonych specjalistów w w pełni wyposażonej sali operacyjnej z anestezjologicznym monitoringiem.",
    price: "od 350 zł",
    color: "teal",
  },
  {
    icon: "🦷",
    title: "Stomatologia zwierząt",
    desc: "Przegląd jamy ustnej, usuwanie kamienia nazębnego, ekstrakcje i leczenie chorób przyzębia. Znieczulenie ogólne w standardzie.",
    price: "od 250 zł",
    color: "orange",
  },
  {
    icon: "📡",
    title: "USG / RTG",
    desc: "Diagnostyka obrazowa najwyższej klasy — ultrasonografia jamy brzusznej i serca, radiografia cyfrowa. Wyniki tego samego dnia.",
    price: "od 150 zł",
    color: "teal",
  },
  {
    icon: "🐾",
    title: "Opieka nad seniorami",
    desc: "Specjalny program geriatryczny dla zwierząt po 7. roku życia. Badania krwi, ocena bólu, dostosowanie diety i suplementacji.",
    price: "od 120 zł",
    color: "brown",
  },
  {
    icon: "🏥",
    title: "Opieka całodobowa",
    desc: "Nasz dyżur nocny i weekendowy gwarantuje pomoc w nagłych przypadkach. Hospitalizacja i intensywna terapia 24/7.",
    price: "od 200 zł",
    color: "brown",
  },
];

const team = [
  {
    name: "lek. wet. Anna Kowalska",
    role: "Chirurg & Kierownik Kliniki",
    spec: "Chirurgia tkanek miękkich, ortopedia",
    img: "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=600&q=80",
    years: 12,
    emoji: "🐕",
  },
  {
    name: "lek. wet. Marek Nowak",
    role: "Internista",
    spec: "Choroby wewnętrzne, diagnostyka obrazowa",
    img: "https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?auto=format&fit=crop&w=600&q=80",
    years: 8,
    emoji: "🐈",
  },
  {
    name: "lek. wet. Zofia Wiśniewska",
    role: "Stomatolog weterynaryjny",
    spec: "Stomatologia, choroby jamy ustnej",
    img: "https://images.unsplash.com/photo-1594824476967-48c8b964273f?auto=format&fit=crop&w=600&q=80",
    years: 6,
    emoji: "🐇",
  },
  {
    name: "lek. wet. Piotr Jabłoński",
    role: "Specjalista geriatrii",
    spec: "Opieka nad seniorami, kardiologia",
    img: "https://images.unsplash.com/photo-1582750433449-648ed127bb54?auto=format&fit=crop&w=600&q=80",
    years: 10,
    emoji: "🐾",
  },
];

const schedule = [
  { day: "Poniedziałek – Piątek", hours: "8:00 – 20:00" },
  { day: "Sobota", hours: "9:00 – 17:00" },
  { day: "Niedziela", hours: "10:00 – 15:00" },
  { day: "Dyżur nocny (całą dobę)", hours: "📞 +48 22 456 78 90" },
];

const reviews = [
  {
    name: "Katarzyna M.",
    pet: "właścicielka Maksa (labrador)",
    text: "Niesamowity zespół! Dr Kowalska operowała naszego Maksa i efekt jest fenomenalny. Przez cały czas czułyśmy się zaopiekowane, personel cały czas informował o stanie psa. Polecam z całego serca!",
    stars: 5,
    avatar: "🐕",
  },
  {
    name: "Tomasz W.",
    pet: "właściciel Piratki (kot bengalski)",
    text: "Najlepsza klinika weterynaryjna w Warszawie. Profesjonalizm na każdym kroku, nowoczesny sprzęt, a przede wszystkim prawdziwa troska o zwierzę. Mój kot nigdy nie był tak spokojny u weterynarza.",
    stars: 5,
    avatar: "🐈",
  },
  {
    name: "Agnieszka L.",
    pet: "właścicielka Buni (króliczka)",
    text: "Świetna opieka nad moją Bunią po zabiegu. Dr Wiśniewska to prawdziwa fachowiec, wytłumaczyła mi wszystko szczegółowo. Gabinet jest czysty, przyjemny i zwierzęta czują się komfortowo.",
    stars: 5,
    avatar: "🐇",
  },
  {
    name: "Rafał K.",
    pet: "właściciel Bolka (golden retriever)",
    text: "Korzystamy z kliniki od 5 lat i nigdy się nie zawiedliśmy. Program opieki nad seniorem dla naszego Bolka jest na najwyższym poziomie. Serdecznie polecam wszystkim miłośnikom zwierząt.",
    stars: 5,
    avatar: "🐾",
  },
];

const stats = [
  { value: 3200, label: "pacjentów rocznie", suffix: "+" },
  { value: 15, label: "lat doświadczenia", suffix: "" },
  { value: 98, label: "zadowolonych właścicieli", suffix: "%" },
  { value: 24, label: "godziny dyżuru", suffix: "/7" },
];
---

<Layout>
  <!-- ═══════════════════════════════════════════ NAV ═══ -->
  <nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-20">
        <!-- Logo -->
        <a href="#" class="flex items-center gap-2 group">
          <span class="text-2xl md:text-3xl font-display font-800 text-[#2c2622] group-hover:text-[#f59e42] transition-colors duration-200">
            Cztery<span class="text-[#f59e42]">Łapy</span>
          </span>
          <svg width="32" height="32" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="hidden sm:block">
            <ellipse cx="20" cy="14" rx="7" ry="9" fill="#f59e42" opacity="0.9"/>
            <ellipse cx="44" cy="14" rx="7" ry="9" fill="#f59e42" opacity="0.9"/>
            <ellipse cx="10" cy="30" rx="6" ry="8" fill="#f59e42" opacity="0.7"/>
            <ellipse cx="54" cy="30" rx="6" ry="8" fill="#f59e42" opacity="0.7"/>
            <ellipse cx="32" cy="44" rx="16" ry="14" fill="#f59e42"/>
          </svg>
        </a>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-6 lg:gap-8">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="font-body font-600 text-[#2c2622] hover:text-[#f59e42] transition-colors duration-200 text-sm lg:text-base relative group"
            >
              {link.label}
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#f59e42] rounded-full transition-all duration-300 group-hover:w-full"></span>
            </a>
          ))}
          <a
            href="#kontakt"
            class="bg-[#f59e42] text-white font-display font-700 px-5 py-2.5 rounded-full hover:bg-[#e08c2e] transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 text-sm lg:text-base"
          >
            Umów wizytę
          </a>
        </div>

        <!-- Burger -->
        <button id="burger" class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-[#fde4bc] transition-colors" aria-label="Menu">
          <span class="block w-6 h-0.5 bg-[#2c2622] rounded transition-all duration-200"></span>
          <span class="block w-6 h-0.5 bg-[#2c2622] rounded transition-all duration-200"></span>
          <span class="block w-4 h-0.5 bg-[#2c2622] rounded transition-all duration-200"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-[#fff7ec] border-t border-[#fde4bc] shadow-lg">
      <div class="px-4 py-4 flex flex-col gap-3">
        {navLinks.map(link => (
          <a href={link.href} class="font-body font-600 text-[#2c2622] hover:text-[#f59e42] py-2 border-b border-[#fde4bc] transition-colors">
            {link.label}
          </a>
        ))}
        <a href="#kontakt" class="mt-2 bg-[#f59e42] text-white font-display font-700 px-5 py-3 rounded-full text-center hover:bg-[#e08c2e] transition-colors">
          Umów wizytę
        </a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════ HERO ═══ -->
  <header class="relative min-h-screen flex items-center bg-[#2c2622] overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1600&q=80"
        alt="Szczęśliwy pies w klinice"
        class="w-full h-full object-cover"
      />
      <!-- Warm gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#2c2622]/85 via-[#2c2622]/60 to-[#6b4f3a]/30"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#2c2622]/50 via-transparent to-transparent"></div>
    </div>

    <!-- Decorative blobs -->
    <div class="absolute top-20 right-10 w-64 h-64 rounded-full bg-[#f59e42]/10 blur-3xl float-anim pointer-events-none"></div>
    <div class="absolute bottom-20 right-32 w-48 h-48 rounded-full bg-[#2bb3a3]/10 blur-3xl float-anim2 pointer-events-none"></div>

    <!-- Paw prints decoration -->
    <div class="absolute top-1/3 right-8 md:right-16 lg:right-24 opacity-20 pointer-events-none hidden lg:block">
      <svg width="200" height="300" viewBox="0 0 200 300" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g transform="rotate(-15, 100, 150)">
          <!-- Paw 1 -->
          <ellipse cx="70" cy="30" rx="8" ry="10" fill="white" opacity="0.8"/>
          <ellipse cx="90" cy="25" rx="8" ry="10" fill="white" opacity="0.8"/>
          <ellipse cx="60" cy="48" rx="7" ry="9" fill="white" opacity="0.6"/>
          <ellipse cx="100" cy="43" rx="7" ry="9" fill="white" opacity="0.6"/>
          <ellipse cx="80" cy="58" rx="15" ry="13" fill="white"/>
          <!-- Paw 2 -->
          <ellipse cx="120" cy="110" rx="8" ry="10" fill="white" opacity="0.8"/>
          <ellipse cx="140" cy="105" rx="8" ry="10" fill="white" opacity="0.8"/>
          <ellipse cx="110" cy="128" rx="7" ry="9" fill="white" opacity="0.6"/>
          <ellipse cx="150" cy="123" rx="7" ry="9" fill="white" opacity="0.6"/>
          <ellipse cx="130" cy="138" rx="15" ry="13" fill="white"/>
          <!-- Paw 3 -->
          <ellipse cx="60" cy="200" rx="8" ry="10" fill="white" opacity="0.8"/>
          <ellipse cx="80" cy="195" rx="8" ry="10" fill="white" opacity="0.8"/>
          <ellipse cx="50" cy="218" rx="7" ry="9" fill="white" opacity="0.6"/>
          <ellipse cx="90" cy="213" rx="7" ry="9" fill="white" opacity="0.6"/>
          <ellipse cx="70" cy="228" rx="15" ry="13" fill="white"/>
        </g>
      </svg>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-[#f59e42]/20 backdrop-blur-sm border border-[#f59e42]/40 rounded-full px-4 py-1.5 mb-6">
          <span class="text-[#f59e42] text-sm font-600">🏆 Klinika z 15-letnim doświadczeniem</span>
        </div>

        <h1 class="font-display font-800 text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white leading-tight mb-6">
          Twój pupil<br/>
          <span class="text-[#f59e42] relative">
            zasługuje
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 300 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 8 Q75 2 150 8 Q225 14 298 6" stroke="#2bb3a3" stroke-width="3" stroke-linecap="round" fill="none"/>
            </svg>
          </span>
          <br/>na najlepsze
        </h1>

        <p class="font-body text-lg md:text-xl text-white/80 mb-8 max-w-lg leading-relaxed">
          W Cztery Łapy traktujemy każdego pacjenta jak członka rodziny.
          Profesjonalna opieka, nowoczesny sprzęt i serce pełne troski — dla psów, kotów i nie tylko.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#kontakt"
            class="inline-flex items-center justify-center gap-2 bg-[#f59e42] text-white font-display font-700 text-lg px-8 py-4 rounded-full hover:bg-[#e08c2e] transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-1"
          >
            <span>🐾</span>
            Umów wizytę
          </a>
          <a
            href="#uslugi"
            class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm text-white font-body font-600 text-lg px-8 py-4 rounded-full border border-white/30 hover:bg-white/20 transition-all duration-200"
          >
            Nasze usługi →
          </a>
        </div>

        <!-- Quick stats -->
        <div class="mt-12 flex flex-wrap gap-6">
          <div class="flex items-center gap-2">
            <span class="text-2xl">⭐</span>
            <div>
              <div class="font-display font-700 text-white text-lg">4.97/5</div>
              <div class="text-white/60 text-xs">z 620 opinii</div>
            </div>
          </div>
          <div class="w-px bg-white/20 self-stretch hidden sm:block"></div>
          <div class="flex items-center gap-2">
            <span class="text-2xl">🏥</span>
            <div>
              <div class="font-display font-700 text-white text-lg">Całodobowy</div>
              <div class="text-white/60 text-xs">dyżur i hospitalizacja</div>
            </div>
          </div>
          <div class="w-px bg-white/20 self-stretch hidden sm:block"></div>
          <div class="flex items-center gap-2">
            <span class="text-2xl">📍</span>
            <div>
              <div class="font-display font-700 text-white text-lg">Warszawa</div>
              <div class="text-white/60 text-xs">ul. Miodowa 14</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
      <div class="flex flex-col items-center gap-2 opacity-60">
        <span class="text-white text-xs font-body tracking-widest uppercase">Przewiń</span>
        <div class="w-6 h-10 border-2 border-white/50 rounded-full flex justify-center pt-2">
          <div class="w-1 h-2 bg-white/70 rounded-full animate-bounce"></div>
        </div>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════ O KLINICE ═══ -->
  <section id="o-klinice" class="py-20 md:py-28 bg-[#fff7ec] relative overflow-hidden">
    <!-- Background blob -->
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-[#fde4bc] opacity-60 blur-2xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full bg-[#d1f5f1] opacity-40 blur-2xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Image mosaic -->
        <div class="reveal-left relative">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <div class="rounded-3xl overflow-hidden aspect-[4/5] bg-[#fde4bc]">
                <img
                  src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&w=600&q=80"
                  alt="Szczęśliwy pies"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="rounded-3xl overflow-hidden aspect-square bg-[#d1f5f1]">
                <img
                  src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=600&q=80"
                  alt="Opieka weterynaryjna"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
            </div>
            <div class="space-y-4 pt-8">
              <div class="rounded-3xl overflow-hidden aspect-square bg-[#fde4bc]">
                <img
                  src="https://images.unsplash.com/photo-1596492784531-6e6eb5ea9993?auto=format&fit=crop&w=600&q=80"
                  alt="Kotek u weterynarza"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="rounded-3xl overflow-hidden aspect-[4/5] bg-[#d1f5f1]">
                <img
                  src="https://images.unsplash.com/photo-1581888227599-779811939961?auto=format&fit=crop&w=600&q=80"
                  alt="Gabinet weterynaryjny"
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
            </div>
          </div>

          <!-- Floating badge -->
          <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 bg-white rounded-2xl shadow-xl px-6 py-4 flex items-center gap-3 border border-[#fde4bc]">
            <span class="text-3xl pulse-heart">❤️</span>
            <div>
              <div class="font-display font-700 text-[#2c2622] text-lg">Z miłością do zwierząt</div>
              <div class="text-[#6b4f3a]/70 text-sm font-body">od 2009 roku</div>
            </div>
          </div>
        </div>

        <!-- Text content -->
        <div class="reveal-right">
          <div class="inline-flex items-center gap-2 bg-[#fde4bc] rounded-full px-4 py-1.5 mb-5">
            <span class="text-[#f59e42]">🐾</span>
            <span class="font-body font-600 text-[#6b4f3a] text-sm">O naszej klinice</span>
          </div>

          <h2 class="font-display font-800 text-4xl md:text-5xl text-[#2c2622] mb-6 leading-tight">
            Miejsce, gdzie<br/>
            <span class="text-[#2bb3a3]">zwierzęta</span> są<br/>
            najważniejsze
          </h2>

          <p class="font-body text-[#6b4f3a] text-lg leading-relaxed mb-6">
            Klinika Cztery Łapy powstała z pasji do zwierząt i przekonania, że każdy pupil zasługuje na opiekę medyczną najwyższej klasy. Od ponad 15 lat służymy mieszkańcom Warszawy, łącząc nowoczesną medycynę z ciepłym, ludzkim podejściem.
          </p>

          <p class="font-body text-[#6b4f3a]/80 text-base leading-relaxed mb-8">
            Nasz zespół tworzą doświadczeni lekarze weterynarii — specjaliści z pasją, którzy nieustannie podnoszą kwalifikacje. Wyposażenie kliniki spełnia najwyższe standardy, a atmosfera sprawia, że nawet nerwowe zwierzęta szybko się uspokajają.
          </p>

          <!-- Feature list -->
          <div class="grid grid-cols-2 gap-3 mb-8">
            {[
              "Nowoczesny sprzęt diagnostyczny",
              "Certyfikowani specjaliści",
              "Przyjazna atmosfera",
              "Dyżur całodobowy",
              "Pełna dokumentacja medyczna",
              "Apteka weterynaryjna",
            ].map(feat => (
              <div class="flex items-center gap-2">
                <span class="w-5 h-5 rounded-full bg-[#2bb3a3] flex items-center justify-center flex-shrink-0">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none">
                    <path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="font-body text-[#2c2622] text-sm">{feat}</span>
              </div>
            ))}
          </div>

          <a
            href="#kontakt"
            class="inline-flex items-center gap-2 bg-[#f59e42] text-white font-display font-700 px-7 py-3.5 rounded-full hover:bg-[#e08c2e] transition-all duration-200 shadow-md hover:-translate-y-0.5"
          >
            Umów wizytę 🐾
          </a>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="mt-20 md:mt-24 grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map((stat, i) => (
          <div class={`reveal delay-${(i + 1) * 100} bg-white rounded-3xl p-6 text-center shadow-sm border border-[#fde4bc] hover:shadow-md hover:-translate-y-1 transition-all duration-300`}>
            <div class="font-display font-800 text-4xl md:text-5xl text-[#f59e42] mb-1">
              <span data-count={stat.value}>0</span>{stat.suffix}
            </div>
            <div class="font-body text-[#6b4f3a] text-sm mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ USŁUGI ═══ -->
  <section id="uslugi" class="py-20 md:py-28 bg-[#f5e8d0] relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#f59e42]/30 to-transparent"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <div class="inline-flex items-center gap-2 bg-[#fff7ec] rounded-full px-4 py-1.5 mb-5">
          <span class="text-[#2bb3a3]">🏥</span>
          <span class="font-body font-600 text-[#6b4f3a] text-sm">Nasze usługi</span>
        </div>
        <h2 class="font-display font-800 text-4xl md:text-5xl text-[#2c2622] mb-4">
